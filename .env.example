# Database Configuration
DATABASE_URL="postgresql://username:password@ep-xxx.us-east-1.aws.neon.tech:5432/mentordb?sslmode=require"

# Authentication (REQUIRED in production)
AUTH_SECRET="your-super-secure-jwt-secret-key-min-64-characters-long"

# Next.js Configuration
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_WS_URL="" # Example: wss://your-realtime-gateway.example/ws
NEXT_PUBLIC_PUSHER_KEY=""
NEXT_PUBLIC_PUSHER_CLUSTER=""

# Optional: Analytics
NEXT_PUBLIC_ANALYTICS_ID=""

# Payments (Flooz / TMoney)
FLOOZ_API_URL=""
FLOOZ_API_TOKEN=""
TMONEY_API_URL=""
TMONEY_API_TOKEN=""
PAYMENT_WEBHOOK_SECRET=""

# Notifications providers
RESEND_API_KEY=""
RESEND_FROM_EMAIL="Execly <noreply@your-domain.com>"
WHATSAPP_API_URL=""
WHATSAPP_API_TOKEN=""

# Vercel Blob
BLOB_READ_WRITE_TOKEN=""

# Pusher server
PUSHER_APP_ID=""
PUSHER_KEY=""
PUSHER_SECRET=""
PUSHER_CLUSTER=""

# Optional: File Upload Service (for future features)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Optional: Redis (for caching and sessions)
REDIS_URL=""

# Development Settings
SKIP_EMAIL_VERIFICATION="true"
ENABLE_DEBUG_LOGS="true"
