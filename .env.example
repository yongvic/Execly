# Database Configuration
DATABASE_URL="postgresql://username:password@ep-xxx.us-east-1.aws.neon.tech:5432/mentordb?sslmode=require"

# Authentication (REQUIRED in production)
AUTH_SECRET="your-super-secure-jwt-secret-key-min-64-characters-long"

# Next.js Configuration
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Optional: Analytics
NEXT_PUBLIC_ANALYTICS_ID=""

# Optional: Email Service (for future features)
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASS=""

# Optional: File Upload Service (for future features)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Optional: Redis (for caching and sessions)
REDIS_URL=""

# Development Settings
SKIP_EMAIL_VERIFICATION="true"
ENABLE_DEBUG_LOGS="true"
