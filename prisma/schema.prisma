generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String     @id @default(cuid())
  email     String     @unique
  password  String
  name      String
  phone     String?    @unique
  country   String?
  avatarUrl String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  role      Role       @default(USER)
  resetToken        String?   @unique
  resetTokenExpires DateTime?
  cart      CartItem[]
  favorites Favorite[]
  orders    Order[]
  payments  Payment[]
  reviews   Review[]
  analyticsEvents AnalyticsEvent[]
  sentMessages Message[] @relation("MessageSender")
  notifications Notification[]
  notificationPreferences NotificationPreference?
  supportThreads ChatThread[] @relation("ClientThreads")
}

model Service {
  id              String     @id @default(cuid())
  slug            String     @unique
  name            String
  category        String
  description     String
  longDescription String?
  price           Float
  currency        Currency   @default(XOF)
  image           String?
  rating          Float      @default(4.5)
  reviewCount     Int        @default(0)
  deliveryDays    Int        @default(3)
  provider        String
  providerImage   String?
  providerRating  Float      @default(4.5)
  included        String?
  isActive        Boolean    @default(true)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  cartItems       CartItem[]
  deliveryOptions ServiceDeliveryOption[]
  favorites       Favorite[]
  orders          Order[]
  reviews         Review[]
  templates       Template[]
}

model CartItem {
  id        String   @id @default(cuid())
  userId    String
  serviceId String
  quantity  Int      @default(1)
  addedAt   DateTime @default(now())
  service   Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, serviceId])
}

model Order {
  id             String    @id @default(cuid())
  userId         String
  serviceId      String
  templateId     String?
  quantity       Int       @default(1)
  totalPrice     Float
  status         OrderStatus @default(PENDING)
  deliveryDate   DateTime?
  notes          String?
  customizationBrief String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deadlineDate   DateTime?
  deliverableUrl String?
  isExpress      Boolean   @default(false)
  paymentId      String?
  payment        Payment?  @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  service        Service   @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  template       Template? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  review         Review?
  deliverables   Deliverable[]
  thread         ChatThread?
}

model Template {
  id           String            @id @default(cuid())
  serviceId    String
  slug         String            @unique
  name         String
  category     String
  description  String
  previewImage String
  previewUrl   String?
  tags         String?
  priceDelta   Float             @default(0)
  deliveryDeltaDays Int          @default(0)
  isActive     Boolean           @default(true)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  orders       Order[]
  service      Service           @relation(fields: [serviceId], references: [id], onDelete: Cascade)
}

model ServiceDeliveryOption {
  id             String   @id @default(cuid())
  serviceId      String
  label          String
  turnaroundDays Int
  priceMultiplier Float
  isDefault      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  service        Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
}

model Payment {
  id               String        @id @default(cuid())
  userId           String
  amount           Float
  currency         Currency      @default(XOF)
  method           PaymentMethod
  phone            String
  status           PaymentStatus @default(PENDING)
  providerRef      String?       @unique
  otpCode          String?
  otpExpiresAt     DateTime?
  otpConfirmedAt   DateTime?
  providerResponse String?
  callbackPayload  String?
  metadata         String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders           Order[]
}

model Review {
  id        String   @id @default(cuid())
  orderId   String   @unique
  userId    String
  serviceId String
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  service   Service  @relation(fields: [serviceId], references: [id])
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  serviceId String
  addedAt   DateTime @default(now())
  service   Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, serviceId])
}

model AnalyticsEvent {
  id         String   @id @default(cuid())
  name       String
  properties String?
  createdAt  DateTime @default(now())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([name, createdAt])
  @@index([createdAt])
}

model Deliverable {
  id           String   @id @default(cuid())
  orderId       String
  fileName      String
  blobUrl       String
  mimeType      String?
  fileSize      Int?
  uploadedById  String?
  uploadedAt    DateTime @default(now())
  order         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, uploadedAt])
}

model ChatThread {
  id          String   @id @default(cuid())
  orderId      String   @unique
  customerId   String
  isClosed     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  customer     User     @relation("ClientThreads", fields: [customerId], references: [id], onDelete: Cascade)
  messages     Message[]
}

model Message {
  id          String      @id @default(cuid())
  threadId    String
  senderId    String
  body        String
  kind        MessageKind @default(TEXT)
  isRead      Boolean     @default(false)
  createdAt   DateTime    @default(now())
  thread      ChatThread  @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sender      User        @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
}

model Notification {
  id          String               @id @default(cuid())
  userId      String
  title       String
  body        String
  channel     NotificationChannel  @default(IN_APP)
  isRead      Boolean              @default(false)
  metadata    String?
  createdAt   DateTime             @default(now())
  user        User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
}

model NotificationPreference {
  id            String   @id @default(cuid())
  userId        String   @unique
  inAppEnabled  Boolean  @default(true)
  emailEnabled  Boolean  @default(true)
  whatsappEnabled Boolean @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
}

enum Role {
  USER
  ADMIN
  MODERATOR
  SUPER_ADMIN
}

enum PaymentMethod {
  FLOOZ
  TMONEY
}

enum PaymentStatus {
  PENDING
  OTP_SENT
  CONFIRMED
  FAILED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum Currency {
  XOF
}

enum MessageKind {
  TEXT
  FILE
  SYSTEM
}

enum NotificationChannel {
  IN_APP
  EMAIL
  WHATSAPP
}
